{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "product-route": {
        "ClusterId": "productservice-cluster",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "orderservice-cluster",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "productservice-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://productservice"
          }
        }
      },
      "orderservice-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://orderservice"
          }
        }
      }
    }
  }
}
